# Neon PostgreSQL connection strings
# Use Neon pooled URL for DATABASE_URL and non-pooled/direct URL for DIRECT_URL.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Site URL
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Admin login, no Supabase required
ADMIN_EMAIL="you@example.com"
ADMIN_PASSWORD_HASH="paste-the-output-of-npm-run-auth-hash-here"
JWT_SECRET="generate-a-long-random-secret-at-least-32-characters"

# Cloudinary media uploads
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_API_KEY="your-api-key"
CLOUDINARY_API_SECRET="your-api-secret"

# Resend emails
RESEND_API_KEY="re_xxxxxxxxx"
RESEND_FROM_EMAIL="AZALI <orders@yourdomain.com>"
OWNER_NOTIFICATION_EMAIL="you@example.com"

# Optional Google Sheets sync
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_SHEETS_SPREADSHEET_ID=""
